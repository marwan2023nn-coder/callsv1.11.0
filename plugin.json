{
  "id": "com.workspace.calls",
  "name": "المكالمات",
  "description": "يوفّر تكاملاً لاتصالات صوتية فورية داخل workspace",
  "homepage_url": "https://github.com/mattermost/mattermost-plugin-calls/",
  "support_url": "https://github.com/mattermost/mattermost-plugin-calls/issues",
  "icon_path": "assets/plugin_icon.svg",
  "min_server_version": "10.0.0",
  "server": {
    "executables": {
      "linux-amd64": "server/dist/plugin-linux-amd64",
      "linux-arm64": "server/dist/plugin-linux-arm64",
      "freebsd-amd64": "server/dist/plugin-freebsd-amd64",
      "openbsd-amd64": "server/dist/plugin-openbsd-amd64"
    }
  },
  "webapp": {
    "bundle_path": "webapp/dist/main.js"
  },
  "settings_schema": {
    "header":"",
    "footer": "",
    "sections": [
      {
        "key": "GeneralSettings",
        "title": "الإعدادات العامة",
        "subtitle": "إعدادات المشاركين ومشاركة الشاشة والرنين والمزيد",
        "custom": true,
        "fallback": true,
        "settings": [
          {
            "key": "DefaultEnabled",
            "display_name": "وضع الاختبار",
            "type": "custom",
            "help_text": "عند تفعيل وضع الاختبار، سيكون بإمكان مسؤولي النظام فقط بدء المكالمات في القنوات. يساعد ذلك على الاختبار والتأكد من أن المكالمات تعمل كما هو متوقع.",
            "hosting": "on-prem"
          },
          {
            "key": "MaxCallParticipants",
            "display_name": "الحد الأقصى لمشاركي المكالمة",
            "type": "number",
            "help_text": "العدد الأقصى للمشاركين الذين يمكنهم الانضمام إلى مكالمة. إذا تُرك الحقل فارغاً أو تم تعيينه إلى 0، فسيكون العدد غير محدود.",
            "default": 0,
            "hosting": "on-prem"
          },
          {
            "key": "AllowScreenSharing",
            "display_name": "السماح بمشاركة الشاشة",
            "type": "bool",
            "default": true,
            "help_text": "عند تفعيل هذا الخيار، يمكن لمشاركي المكالمة مشاركة شاشاتهم."
          },
          {
            "key": "EnableSimulcast",
            "display_name": "تفعيل Simulcast لمشاركة الشاشة (تجريبي)",
            "type": "bool",
            "default": false,
            "help_text": "عند تفعيل هذا الخيار، سيتم تفعيل Simulcast لمشاركة الشاشة. يمكن أن يساعد ذلك على تحسين جودة مشاركة الشاشة."
          },
          {
            "key": "EnableRinging",
            "display_name": "تفعيل رنين المكالمات",
            "type": "bool",
            "default": false,
            "help_text": "عند تفعيل هذا الخيار، سيتم تفعيل الرنين: سيتلقى المشاركون في الرسائل المباشرة أو الجماعية تنبيهاً على سطح المكتب وإشعار رنين عند بدء مكالمة. يتطلب تغيير هذا الإعداد إعادة تشغيل الإضافة."
          },
          {
            "key": "EnableAV1",
            "display_name": "تفعيل ترميز AV1 لمشاركة الشاشة (تجريبي)",
            "type": "bool",
            "default": false,
            "help_text": "عند تفعيل هذا الخيار، سيتم استخدام ترميز AV1 لترميز مسارات مشاركة الشاشة. قد يؤدي ذلك إلى تحسين جودة مشاركة الشاشة لدى العملاء الذين يدعمونه.\nملاحظة: لن يتم تطبيق هذا الإعداد عندما يكون EnableSimulcast مفعّلاً."
          },
          {
            "key": "EnableDCSignaling",
            "display_name": "استخدام قنوات البيانات للإشارة (تجريبي)",
            "type": "bool",
            "default": false,
            "help_text": "عند تفعيل هذا الخيار، ستستخدم التطبيقات قنوات بيانات WebRTC لإشارة مسارات الوسائط الجديدة. قد ينتج عن ذلك عملية أكثر كفاءة وأقل عرضة لحدوث تعارضات، خصوصاً عند تكرار انقطاع WebSocket."
          },
          {
            "display_name": "النغمة الافتراضية أثناء إجراء اتصال (Ringback)",
            "type": "dropdown",
            "default": "default",
            "help_text": "النغمة الافتراضية التي سيتم تشغيلها أثناء إجراء اتصال عندما لا يختار المستخدم نغمة مخصصة.",
            "options": [
              {
                "display_name": "الافتراضي (ring.mp3)",
                "value": "default"
              },
              {
                "display_name": "TMessagesProj voip_ringback",
                "value": "tmessagesproj_src_main_res_raw_voip_ringback.mp3"
              },
              {
                "display_name": "zamel_1",
                "value": "zamel_1.mp3"
              },
              {
                "display_name": "zamel_2",
                "value": "zamel_2.mp3"
              },
              {
                "display_name": "Dynamic",
                "value": "builtin:Dynamic"
              },
              {
                "display_name": "Calm",
                "value": "builtin:Calm"
              },
              {
                "display_name": "Urgent",
                "value": "builtin:Urgent"
              },
              {
                "display_name": "Cheerful",
                "value": "builtin:Cheerful"
              }
            ]
          }
        ]
      },
